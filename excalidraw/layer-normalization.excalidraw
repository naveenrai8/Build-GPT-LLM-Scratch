      "link": null,
      "locked": false,
      "text": "import numpy as np\ndata = [1.1, 0.8, 2.3, 4.4]\n\nmean = np.mean(data)\nvar = np.var(data)\nprint(mean)\nprint(var)\n\noutput = [float((i - mean) / var**0.5) for i in data]\nprint(output)\n\ndata = [-0.74, -0.95, 0.1, 1.59]\n\nprint(np.mean(output))\nprint(np.var(output))",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "import numpy as np\ndata = [1.1, 0.8, 2.3, 4.4]\n\nmean = np.mean(data)\nvar = np.var(data)\nprint(mean)\nprint(var)\n\noutput = [float((i - mean) / var**0.5) for i in data]\nprint(output)\n\ndata = [-0.74, -0.95, 0.1, 1.59]\n\nprint(np.mean(output))\nprint(np.var(output))",
      "autoResize": true,
      "lineHeight": 1.35
    },
