    {
      "id": "eZmbM_f7nvQHa_ZcV0cq0",
      "type": "text",
      "x": -139.76434746582294,
      "y": 1219.8791152793924,
      "width": 678.2377839679527,
      "height": 135,
      "angle": 0,
      "strokeColor": "#0c8599",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
