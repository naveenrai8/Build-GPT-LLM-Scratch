      "updated": 1778559925287,
      "link": null,
      "locked": false,
      "text": "Number of rows = Number of output dimensions from input matrix",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Number of rows = Number of output dimensions from input matrix",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "U42e-CIEcLLo5QD6OUcVh",
      "type": "text",
      "x": 2299.972865739605,
      "y": 194.35604009184047,
      "width": 547.6634521484375,
      "height": 86.4,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "NpYIh-1B5qPxoumPBo6tK"
      ],
      "frameId": null,
      "index": "b5x",
      "roundness": null,
      "seed": 1650089411,
      "version": 444,
      "versionNonce": 1297454061,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778559925287,
      "link": null,
      "locked": false,
      "text": "Number of columns = 2 here \n    - formula => number of columns = (output dimensions / number of heads)\n    - if number of heads = 12 and output dimension = 768\n        - number of columsn = 768 / 12 = 64",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Number of columns = 2 here \n    - formula => number of columns = (output dimensions / number of heads)\n    - if number of heads = 12 and output dimension = 768\n        - number of columsn = 768 / 12 = 64",
      "autoResize": true,
      "lineHeight": 1.35
    },
