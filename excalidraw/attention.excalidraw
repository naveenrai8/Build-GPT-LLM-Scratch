      "updated": 1778559925287,
      "link": null,
      "locked": false,
      "text": "Number of rows = Number of output dimensions from input matrix",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Number of rows = Number of output dimensions from input matrix",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "P0mSZzNvQkRP5UGJxQOtF",
      "type": "text",
      "x": 4741.844318811661,
      "y": 245.83900657290923,
      "width": 547.6634521484375,
      "height": 86.4,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "4YHTN67t4hVTfy7alaNYO"
      ],
      "frameId": null,
      "index": "b9m",
      "roundness": null,
      "seed": 1688663523,
      "version": 477,
      "versionNonce": 1440091597,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778559925287,
      "link": null,
      "locked": false,
      "text": "Number of columns = 2 here \n    - formula => number of columns = (output dimensions / number of heads)\n    - if number of heads = 12 and output dimension = 768\n        - number of columsn = 768 / 12 = 64",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Number of columns = 2 here \n    - formula => number of columns = (output dimensions / number of heads)\n    - if number of heads = 12 and output dimension = 768\n        - number of columsn = 768 / 12 = 64",
      "autoResize": true,
      "lineHeight": 1.35
    },
